# Transcript generation provider: "claude" or "ollama"
# SUBTITLER_TRANSCRIPT_PROVIDER=claude

# --- Claude (default) ---
# Required when SUBTITLER_TRANSCRIPT_PROVIDER=claude
SUBTITLER_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the Claude model
# SUBTITLER_TRANSCRIPT_MODEL=claude-sonnet-4-6

# --- Ollama (local, free) ---
# Run: ollama pull llama3.1:8b  before starting the server
# SUBTITLER_TRANSCRIPT_PROVIDER=ollama
# SUBTITLER_OLLAMA_MODEL=llama3.1:8b
# SUBTITLER_OLLAMA_BASE_URL=http://localhost:11434

# Optional: custom HuggingFace cache directory
# SUBTITLER_HF_CACHE_DIR=/path/to/hf/cache

# Optional: whisper.cpp binary path (auto-detected if omitted)
# SUBTITLER_WHISPER_CPP_BINARY=/usr/local/bin/whisper-cli

# Optional: directory containing GGML .bin model files
# SUBTITLER_WHISPER_CPP_MODEL_DIR=/path/to/models

# Optional: enable Core ML inference for whisper.cpp
# SUBTITLER_WHISPER_CPP_USE_COREML=false
